{
  "hosting": {
    "public": "orbita_web/src/main/resources/templates",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.exe",
      "**/*.dll",
      "**/*.bat",
      "**/*.apk",
      "**/*.ipa",
      ".venv/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/login.html"
      },
