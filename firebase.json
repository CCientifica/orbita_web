        "destination": "/estadistica-diaria.html"
      },
      {
        "source": "/acumulado-mensual",
        "destination": "/acumulado-mensual.html"
      },
      {
        "source": "/dashboard-citas-cx-imx",
        "destination": "/dashboard-citas-cx-imx.html"
      },
      {
        "source": "/consulta-cx-imdx",
        "destination": "/consulta-cx-imdx.html"
      },
      {
        "source": "/altocosto",
        "destination": "/altocosto.html"
      },
      {
        "source": "/porfiria",
        "destination": "/porfiria.html"
      },
      {
        "source": "/usuarios",
        "destination": "/usuarios.html"
      },
      {
        "source": "/home",
        "destination": "/home.html"
      },
      {
        "source": "/dashboard",
        "destination": "/home.html"
      },
      {
        "source": "/predictor-los",
        "destination": "/predictor-los.html"
      },
      {
        "source": "/historico-los",
        "destination": "/historico-los.html"
