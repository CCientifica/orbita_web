      {
        "source": "/ams",
        "destination": "/ams.html"
      },
      {
        "source": "/isa",
        "destination": "/isa.html"
      },
      {
        "source": "/dasheco",
        "destination": "/dasheco.html"
      },
      {
        "source": "/otroseco",
        "destination": "/otroseco.html"
      },
      {
        "source": "/auxiliares-enf-rcf",
        "destination": "/auxiliares-enf-rcf.html"
